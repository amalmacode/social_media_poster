{
  "name": "social-media-poster",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-platform social media publisher MVP",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "worker": "node workers/publishWorker.js",
    "css:build": "tailwindcss -i ./public/css/input.css -o ./public/css/app.css --minify",
    "css:watch": "tailwindcss -i ./public/css/input.css -o ./public/css/app.css --watch",
    "db:schema": "psql \"$DATABASE_URL\" -f database/schema.sql",
    "lint": "node --check server.js && node --check app.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.34.2",
    "connect-flash": "^0.1.1",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "joi": "^17.13.3",
    "method-override": "^3.0.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.9",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.13.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "nodemon": "^3.1.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
