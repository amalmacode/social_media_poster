<div class="mx-auto max-w-lg">
  <div class="mb-5 flex items-center gap-3">
    <a href="/accounts" class="text-sm text-black/50 hover:text-black">← Accounts</a>
    <span class="text-black/20">/</span>
    <span class="text-sm font-medium">Connect Pinterest with access token</span>
  </div>

  <div class="rounded-lg border border-black/10 bg-white p-6 shadow-sm">

    <!-- Pinterest logo + heading -->
    <div class="mb-5 flex items-center gap-3">
      <span class="flex h-10 w-10 items-center justify-center rounded-full bg-[#E60023]">
        <svg viewBox="0 0 24 24" class="h-5 w-5 fill-white"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
      </span>
      <div>
        <h1 class="text-lg font-semibold">Pinterest — Sandbox / Token</h1>
        <p class="text-xs text-black/45">Use a manually generated access token from the Pinterest developer portal</p>
      </div>
    </div>

    <!-- Instructions -->
    <div class="mb-5 rounded-md border border-amber-100 bg-amber-50 p-4 text-sm text-amber-800">
      <p class="font-semibold mb-1">How to get your access token</p>
      <ol class="list-decimal list-inside space-y-1 text-xs">
        <li>Go to <strong>developers.pinterest.com → My Apps → your app</strong></li>
        <li>Open the <strong>Auth</strong> tab (or "Generate access token")</li>
        <li>Click <strong>Generate token</strong> — select the scopes: <code class="rounded bg-amber-100 px-1">boards:read</code>, <code class="rounded bg-amber-100 px-1">pins:write</code>, <code class="rounded bg-amber-100 px-1">user_accounts:read</code></li>
        <li>Copy the generated token and paste it below</li>
      </ol>
    </div>

    <form method="post" action="/accounts/pinterest/connect-token">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <label class="block text-sm font-medium">Access token</label>
      <textarea name="accessToken" rows="4" required
                placeholder="pina_..."
                class="mt-1 w-full rounded-md border border-black/15 px-3 py-2 font-mono text-xs focus:outline-none focus:ring-2 focus:ring-[#E60023]/30"></textarea>
      <p class="mt-1 text-xs text-black/40">Paste the full token — it typically starts with <code>pina_</code></p>

      <button class="mt-4 w-full rounded-md bg-[#E60023] px-4 py-2.5 text-sm font-semibold text-white hover:bg-[#cc001f] transition-colors">
        Connect Pinterest
      </button>
    </form>

  </div>

  <p class="mt-4 text-center text-xs text-black/35">
    Have OAuth credentials?
    <a href="/accounts/pinterest/connect" class="underline hover:text-black">Use the standard OAuth flow instead</a>
  </p>
</div>
