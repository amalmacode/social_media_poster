<%
  const platformColor = {
    instagram: 'bg-gradient-to-r from-purple-500 to-pink-500 text-white',
    facebook:  'bg-blue-600 text-white',
    pinterest: 'bg-[#E60023] text-white',
    youtube:   'bg-[#FF0000] text-white',
    tiktok:    'bg-[#010101] text-white'
  };
  const platformLabel = {
    instagram: 'Instagram', facebook: 'Facebook Page',
    pinterest: 'Pinterest', youtube: 'YouTube', tiktok: 'TikTok'
  };
%>
<div class="space-y-8">

  <!-- ── Brand accounts ─────────────────────────────────────────────────── -->
  <section class="space-y-4">
    <div class="flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-semibold tracking-tight">Brand Accounts</h2>
        <p class="text-sm text-black/55">Group your platform connections into brands. Choose a brand when creating a post.</p>
      </div>
      <button type="button" data-toggle="new-brand-form"
              class="rounded-md border border-black/15 px-3 py-1.5 text-sm font-medium hover:bg-black/5">
        + New brand
      </button>
    </div>

    <form id="new-brand-form" method="post" action="/accounts/brands" class="hidden rounded-lg border border-black/10 bg-white p-4 shadow-sm">
      <div class="flex gap-2">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="text" name="name" placeholder="e.g. TYMA_STORE" maxlength="60" required autofocus
               class="flex-1 rounded-md border border-black/15 px-3 py-2 text-sm">
        <button type="submit" class="rounded-md bg-ink px-4 py-2 text-sm font-semibold text-white">Create</button>
        <button type="button" data-hide="new-brand-form"
                class="rounded-md border border-black/15 px-3 py-2 text-sm font-medium">Cancel</button>
      </div>
    </form>

    <% if (!brandAccounts.length) { %>
      <div class="rounded-lg border border-dashed border-black/15 p-6 text-center text-sm text-black/50">
        No brand accounts yet. Click <strong>+ New brand</strong> to create your first one.
      </div>
    <% } else { %>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <% brandAccounts.forEach(function(brand) { %>
          <div class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-semibold leading-tight"><%= brand.name %></h3>
              <a href="/accounts/brands/<%= brand.id %>"
                 class="rounded px-2 py-1 text-xs font-medium text-black/50 hover:bg-black/5">Manage →</a>
            </div>
            <% if (!brand.members.length) { %>
              <p class="mt-3 text-xs text-black/40">No platforms linked yet.</p>
            <% } else { %>
              <div class="mt-3 flex flex-wrap gap-1.5">
                <% brand.members.forEach(function(m) { %>
                  <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold <%= platformColor[m.platform] || 'bg-black/10 text-black/70' %>">
                    <%= platformLabel[m.platform] || m.platform %>
                    <span class="opacity-75">@<%= m.username %></span>
                  </span>
                <% }) %>
              </div>
            <% } %>
            <p class="mt-2 text-xs text-black/35"><%= brand.members.length %> platform<%= brand.members.length === 1 ? '' : 's' %></p>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

  <!-- ── Platform connections ───────────────────────────────────────────── -->
  <section class="space-y-4">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-2xl font-semibold tracking-tight">Platform Connections</h2>
        <p class="text-sm text-black/55">OAuth tokens are encrypted and never exposed to the browser.</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href="/accounts/instagram/connect" class="inline-flex items-center gap-2 rounded-md bg-gradient-to-r from-purple-500 to-pink-500 px-3 py-1.5 text-sm font-semibold text-white shadow-sm">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          Instagram
        </a>
        <a href="/accounts/youtube/connect" class="inline-flex items-center gap-2 rounded-md bg-[#FF0000] px-3 py-1.5 text-sm font-semibold text-white shadow-sm">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          YouTube
        </a>
        <div class="flex flex-col items-start gap-0.5">
          <a href="/accounts/pinterest/connect" class="inline-flex items-center gap-2 rounded-md bg-[#E60023] px-3 py-1.5 text-sm font-semibold text-white shadow-sm">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            Pinterest
          </a>
          <a href="/accounts/pinterest/connect-token" class="text-xs text-[#E60023]/70 hover:text-[#E60023] hover:underline pl-0.5">Use access token →</a>
        </div>
        <a href="/accounts/tiktok/connect" class="inline-flex items-center gap-2 rounded-md bg-[#010101] px-3 py-1.5 text-sm font-semibold text-white shadow-sm">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 00-.79-.05A6.34 6.34 0 003.15 15.3a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.69a8.27 8.27 0 004.84 1.55V6.79a4.85 4.85 0 01-1.08-.1z"/></svg>
          TikTok
        </a>
      </div>
    </div>

    <% if (!accounts.length) { %>
      <div class="rounded-lg border border-black/10 bg-white p-6 text-sm text-black/60 shadow-sm">
        No platform connections yet. Use the buttons above to connect your accounts.
      </div>
    <% } else { %>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <% accounts.forEach(function(account) { %>
          <%
            const isInstagram = account.platform === 'instagram';
            const isFacebook  = account.platform === 'facebook';
            const isPinterest = account.platform === 'pinterest';
            const isYouTube   = account.platform === 'youtube';
            const isTikTok    = account.platform === 'tiktok';
            const badgeClass  = platformColor[account.platform] || 'bg-black/10 text-black/70';
            const label       = platformLabel[account.platform] || account.platform;
          %>
          <div class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
            <div class="flex items-center justify-between">
              <span class="rounded-full px-2.5 py-0.5 text-xs font-semibold <%= badgeClass %>"><%= label %></span>
            </div>
            <p class="mt-3 text-lg font-semibold leading-tight"><%= account.username %></p>
            <p class="mt-0.5 text-xs text-black/40"><%= account.platform_user_id %></p>
            <% if (account.expires_at) { %>
              <p class="mt-1 text-xs text-black/40">Expires <%= new Date(account.expires_at).toLocaleDateString() %></p>
            <% } %>
            <form method="post" action="/accounts/<%= account.id %>?_method=DELETE" class="mt-4"
                  data-confirm="Disconnect this account?">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="rounded-md border border-red-200 px-3 py-1.5 text-sm font-medium text-red-700 hover:bg-red-50">Disconnect</button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

</div>
