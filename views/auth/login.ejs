<section class="min-h-screen bg-[#f0f2f5] flex flex-col items-center justify-center px-4 py-12 md:flex-row md:items-center md:justify-center md:gap-16 md:px-8 lg:gap-24">

  <!-- Left — branding & marketing -->
  <div class="mb-8 text-center md:mb-0 md:max-w-sm md:text-left lg:max-w-md">
    <h1 class="text-4xl font-bold text-mint tracking-tight lg:text-5xl">Publisher</h1>
    <p class="mt-3 text-xl text-black/70 lg:text-2xl">One place to schedule &amp; publish everywhere.</p>

    <!-- Platform logos -->
    <div class="mt-8 hidden md:block">
      <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-black/35">Publish to all your platforms</p>
      <div class="flex items-center gap-3">

        <!-- Instagram -->
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl" style="background:linear-gradient(135deg,#f9ce34,#ee2a7b,#6228d7)">
          <svg viewBox="0 0 24 24" class="h-6 w-6 fill-white"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </div>

        <!-- YouTube -->
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#FF0000]">
          <svg viewBox="0 0 24 24" class="h-6 w-6 fill-white"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </div>

        <!-- TikTok -->
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#010101]">
          <svg viewBox="0 0 24 24" class="h-6 w-6 fill-white"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        </div>

        <!-- Facebook -->
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#1877F2]">
          <svg viewBox="0 0 24 24" class="h-6 w-6 fill-white"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </div>

        <!-- Pinterest -->
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#E60023]">
          <svg viewBox="0 0 24 24" class="h-6 w-6 fill-white"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
        </div>

      </div>
    </div>

    <!-- Features -->
    <ul class="mt-8 hidden space-y-5 md:block">
      <li class="flex items-start gap-3">
        <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-mint/15 text-mint">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg>
        </span>
        <div>
          <p class="font-semibold text-ink">One workflow for all platforms</p>
          <p class="text-sm text-black/55">Write once, publish to every connected account simultaneously.</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-mint/15 text-mint">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </span>
        <div>
          <p class="font-semibold text-ink">Schedule in advance</p>
          <p class="text-sm text-black/55">Pick a date and time — posts publish automatically.</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-mint/15 text-mint">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 10l-4 4-4-4M12 3v11"/><path d="M5 21h14"/></svg>
        </span>
        <div>
          <p class="font-semibold text-ink">Upload once</p>
          <p class="text-sm text-black/55">One video or image, delivered to all your audiences.</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-mint/15 text-mint">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </span>
        <div>
          <p class="font-semibold text-ink">Private &amp; secure</p>
          <p class="text-sm text-black/55">Tokens encrypted at rest. No ads, no tracking.</p>
        </div>
      </li>
    </ul>
  </div>

  <!-- Right — login card -->
  <div class="w-full max-w-md shrink-0">
    <div class="rounded-xl bg-white p-6 shadow-md">
      <%- include('../partials/flash') %>
      <form method="post" action="/auth/login">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input name="email" type="email" required placeholder="Email address"
               class="w-full rounded-md border border-black/20 px-4 py-3 text-base focus:border-mint focus:outline-none focus:ring-2 focus:ring-mint/20">
        <input name="password" type="password" required placeholder="Password"
               class="mt-3 w-full rounded-md border border-black/20 px-4 py-3 text-base focus:border-mint focus:outline-none focus:ring-2 focus:ring-mint/20">
        <button type="submit"
                class="mt-4 w-full rounded-lg bg-mint py-3 text-lg font-semibold text-white transition-colors hover:bg-mint/90">
          Log in
        </button>
        <div class="mt-3 text-center">
          <a href="/auth/forgot-password" class="text-sm text-mint hover:underline">Forgot password?</a>
        </div>
      </form>
      <div class="my-5 flex items-center gap-3">
        <div class="h-px flex-1 bg-black/10"></div>
        <span class="text-sm text-black/40">or</span>
        <div class="h-px flex-1 bg-black/10"></div>
      </div>
      <div class="text-center">
        <a href="/auth/register"
           class="inline-block rounded-lg border-2 border-mint/70 px-6 py-2.5 text-sm font-semibold text-mint transition-colors hover:bg-mint/5">
          Create new account
        </a>
      </div>
    </div>
    <p class="mt-4 text-center text-xs text-black/35">
      By logging in you agree to our
      <a href="/terms" class="hover:underline">Terms</a> and
      <a href="/privacy" class="hover:underline">Privacy Policy</a>.
    </p>
  </div>

</section>
