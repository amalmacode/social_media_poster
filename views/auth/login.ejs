<section class="flex min-h-screen items-center justify-center px-4">
  <form method="post" action="/auth/login" class="w-full max-w-sm rounded-lg border border-black/10 bg-white p-6 shadow-sm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h1 class="text-2xl font-semibold">Log in</h1>
    <p class="mt-1 text-sm text-black/60">Publish short-form content everywhere from one workflow.</p>
    <label class="mt-6 block text-sm font-medium">Email</label>
    <input name="email" type="email" required class="mt-1 w-full rounded-md border border-black/15 px-3 py-2">
    <label class="mt-4 block text-sm font-medium">Password</label>
    <input name="password" type="password" required class="mt-1 w-full rounded-md border border-black/15 px-3 py-2">
    <button class="mt-6 w-full rounded-md bg-ink px-4 py-2.5 text-sm font-semibold text-white">Log in</button>
    <div class="mt-4 flex justify-between text-sm text-black/60">
      <a href="/auth/register" class="hover:text-ink">Create account</a>
      <a href="/auth/forgot-password" class="hover:text-ink">Forgot password?</a>
    </div>
  </form>
</section>
