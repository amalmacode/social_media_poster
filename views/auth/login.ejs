<section class="flex min-h-screen flex-col items-center justify-center bg-[#f0f2f5] px-4 py-12">

  <!-- Brand -->
  <div class="mb-6 text-center">
    <h1 class="text-5xl font-bold text-mint tracking-tight">Publisher</h1>
    <p class="mt-2 text-lg text-black/60">Schedule and publish everywhere, from one place.</p>
  </div>

  <!-- Card -->
  <div class="w-full max-w-md rounded-xl bg-white p-6 shadow-md">

    <%- include('../partials/flash') %>

    <form method="post" action="/auth/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <input name="email" type="email" required placeholder="Email address"
             class="w-full rounded-md border border-black/20 px-4 py-3 text-base focus:border-mint focus:outline-none focus:ring-2 focus:ring-mint/20">

      <input name="password" type="password" required placeholder="Password"
             class="mt-3 w-full rounded-md border border-black/20 px-4 py-3 text-base focus:border-mint focus:outline-none focus:ring-2 focus:ring-mint/20">

      <button type="submit"
              class="mt-4 w-full rounded-lg bg-mint py-3 text-lg font-semibold text-white hover:bg-mint/90 transition-colors">
        Log in
      </button>

      <div class="mt-3 text-center">
        <a href="/auth/forgot-password" class="text-sm text-mint hover:underline">Forgot password?</a>
      </div>
    </form>

    <div class="my-5 flex items-center gap-3">
      <div class="h-px flex-1 bg-black/10"></div>
      <span class="text-sm text-black/40">or</span>
      <div class="h-px flex-1 bg-black/10"></div>
    </div>

    <div class="text-center">
      <a href="/auth/register"
         class="inline-block rounded-lg border-2 border-mint/70 px-6 py-2.5 text-sm font-semibold text-mint hover:bg-mint/5 transition-colors">
        Create new account
      </a>
    </div>

  </div>

  <p class="mt-6 text-xs text-black/35 text-center">
    By logging in you agree to our
    <a href="/terms" class="hover:underline">Terms</a> and
    <a href="/privacy" class="hover:underline">Privacy Policy</a>.
  </p>

</section>
