<section class="min-h-screen bg-[#f0f2f5] flex flex-col items-center justify-center px-4 py-12 md:flex-row md:items-center md:justify-center md:gap-16 md:px-8 lg:gap-24">

  <!-- Left — branding & marketing (desktop only) -->
  <div class="mb-8 text-center md:mb-0 md:max-w-sm md:text-left lg:max-w-md">
    <h1 class="text-4xl font-bold text-mint tracking-tight lg:text-5xl">Publisher</h1>
    <p class="mt-3 text-xl text-black/70 lg:text-2xl">
      One place to schedule &amp; publish everywhere.
    </p>

    <ul class="mt-8 hidden space-y-5 md:block">
      <li class="flex items-start gap-3">
        <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-mint/15 text-mint">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
        </span>
        <div>
          <p class="font-semibold text-ink">All platforms, one dashboard</p>
          <p class="text-sm text-black/55">Instagram, TikTok, YouTube, Facebook, Pinterest — managed together.</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-mint/15 text-mint">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </span>
        <div>
          <p class="font-semibold text-ink">Schedule in advance</p>
          <p class="text-sm text-black/55">Pick a date and time — posts go out automatically while you focus on creating.</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-mint/15 text-mint">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 10l-4 4-4-4"/><path d="M19 6.5A9 9 0 1 1 12 3"/></svg>
        </span>
        <div>
          <p class="font-semibold text-ink">Upload once, publish everywhere</p>
          <p class="text-sm text-black/55">One video or image, sent to all your connected accounts simultaneously.</p>
        </div>
      </li>
      <li class="flex items-start gap-3">
        <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-mint/15 text-mint">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </span>
        <div>
          <p class="font-semibold text-ink">Your data stays yours</p>
          <p class="text-sm text-black/55">OAuth tokens encrypted at rest. No third-party analytics. No ads.</p>
        </div>
      </li>
    </ul>
  </div>

  <!-- Right — login card -->
  <div class="w-full max-w-md shrink-0">
    <div class="rounded-xl bg-white p-6 shadow-md">

      <%- include('../partials/flash') %>

      <form method="post" action="/auth/login">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <input name="email" type="email" required placeholder="Email address"
               class="w-full rounded-md border border-black/20 px-4 py-3 text-base focus:border-mint focus:outline-none focus:ring-2 focus:ring-mint/20">

        <input name="password" type="password" required placeholder="Password"
               class="mt-3 w-full rounded-md border border-black/20 px-4 py-3 text-base focus:border-mint focus:outline-none focus:ring-2 focus:ring-mint/20">

        <button type="submit"
                class="mt-4 w-full rounded-lg bg-mint py-3 text-lg font-semibold text-white transition-colors hover:bg-mint/90">
          Log in
        </button>

        <div class="mt-3 text-center">
          <a href="/auth/forgot-password" class="text-sm text-mint hover:underline">Forgot password?</a>
        </div>
      </form>

      <div class="my-5 flex items-center gap-3">
        <div class="h-px flex-1 bg-black/10"></div>
        <span class="text-sm text-black/40">or</span>
        <div class="h-px flex-1 bg-black/10"></div>
      </div>

      <div class="text-center">
        <a href="/auth/register"
           class="inline-block rounded-lg border-2 border-mint/70 px-6 py-2.5 text-sm font-semibold text-mint transition-colors hover:bg-mint/5">
          Create new account
        </a>
      </div>
    </div>

    <p class="mt-4 text-center text-xs text-black/35">
      By logging in you agree to our
      <a href="/terms" class="hover:underline">Terms</a> and
      <a href="/privacy" class="hover:underline">Privacy Policy</a>.
    </p>
  </div>

</section>
