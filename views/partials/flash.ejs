<%
  var flashMessages = [].concat(
    (flash.success || []).map(function(m){ return { type: 'success', message: m }; }),
    (flash.error   || []).map(function(m){ return { type: 'error',   message: m }; })
  );
%>
<% if (flashMessages.length) { %>
<script id="flash-data" type="application/json"><%- JSON.stringify(flashMessages) %></script>
<% } %>
