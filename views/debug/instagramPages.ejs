<div class="space-y-5">
  <div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-center">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight">Instagram Page Diagnostics</h1>
      <p class="text-sm text-black/60">Raw Graph API responses from the latest Connect Instagram attempt.</p>
    </div>
    <a href="/debug/instagram-pages.json" class="rounded-md border border-black/10 bg-white px-4 py-2 text-sm font-semibold">JSON</a>
  </div>

  <section class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
    <h2 class="text-lg font-semibold">Token</h2>
    <div class="mt-3 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-4">
      <div><span class="block text-black/50">Type</span><span class="font-medium"><%= tokenDiagnostics.tokenType || 'Unknown' %></span></div>
      <div><span class="block text-black/50">User ID</span><span class="font-medium"><%= tokenDiagnostics.userId || 'Unknown' %></span></div>
      <div><span class="block text-black/50">Granted</span><span class="font-medium"><%= tokenDiagnostics.grantedScopes.join(', ') || 'None' %></span></div>
      <div><span class="block text-black/50">Missing</span><span class="font-medium"><%= tokenDiagnostics.missingScopes.join(', ') || 'None' %></span></div>
    </div>
  </section>

  <section class="grid gap-4">
    <% pages.forEach(function(page) { %>
      <article class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
        <div class="flex flex-col justify-between gap-2 sm:flex-row sm:items-start">
          <div>
            <p class="text-sm font-medium text-black/50"><%= page.page_id %></p>
            <h2 class="text-xl font-semibold"><%= page.page_name %></h2>
          </div>
          <span class="rounded-md px-3 py-1 text-sm font-semibold <%= page.has_instagram ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' %>">
            <%= page.has_instagram ? 'Instagram found' : 'No Instagram returned' %>
          </span>
        </div>

        <% if (page.instagram_business_account) { %>
          <div class="mt-4 rounded-md bg-emerald-50 p-3 text-sm">
            <span class="font-semibold">Instagram business account:</span>
            <pre class="mt-2 whitespace-pre-wrap text-xs"><%= JSON.stringify(page.instagram_business_account, null, 2) %></pre>
          </div>
        <% } %>

        <% if (page.connected_instagram_account && !page.instagram_business_account) { %>
          <div class="mt-4 rounded-md bg-amber-50 p-3 text-sm text-amber-900">
            <span class="font-semibold">Connected Instagram account found, but not as instagram_business_account:</span>
            <pre class="mt-2 whitespace-pre-wrap text-xs"><%= JSON.stringify(page.connected_instagram_account, null, 2) %></pre>
          </div>
        <% } %>

        <% if (page.error) { %>
          <div class="mt-4 rounded-md bg-red-50 p-3 text-sm text-red-900">
            <span class="font-semibold">Graph API Error</span>
            <pre class="mt-2 whitespace-pre-wrap text-xs"><%= JSON.stringify(page.error, null, 2) %></pre>
          </div>
        <% } %>

        <div class="mt-4">
          <p class="text-sm font-semibold">Raw response</p>
          <pre class="mt-2 max-h-80 overflow-auto rounded-md bg-black/[0.03] p-3 text-xs"><%= JSON.stringify(page.raw_response, null, 2) %></pre>
        </div>
      </article>
    <% }) %>
  </section>
</div>
