<div class="mx-auto max-w-xl px-4 py-20 text-center">
  <div class="mb-4 text-5xl">✓</div>
  <h1 class="mb-2 text-2xl font-bold">Data Deletion Initiated</h1>
  <p class="mb-6 text-black/60">Your data deletion request has been received and processed.</p>
  <% if (code) { %>
    <div class="mb-6 rounded-lg border border-black/10 bg-white p-4">
      <p class="text-xs text-black/40">Confirmation code</p>
      <p class="font-mono text-sm font-medium"><%= code %></p>
    </div>
  <% } %>
  <p class="text-sm text-black/50">All connected account data associated with your Facebook/Instagram account has been removed from our servers. If you have additional data to remove, please contact <a href="mailto:contact@urlyapp.com" class="text-mint underline">contact@urlyapp.com</a>.</p>
</div>
