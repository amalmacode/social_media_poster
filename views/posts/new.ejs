<div class="grid gap-5 lg:grid-cols-[340px_1fr]">
  <section class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
    <h1 class="text-xl font-semibold">Media</h1>
    <form method="post" action="/posts/media?_csrf=<%= encodeURIComponent(csrfToken) %>" enctype="multipart/form-data" class="mt-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label class="flex min-h-44 cursor-pointer flex-col items-center justify-center rounded-lg border-2 border-dashed border-black/15 bg-black/[0.02] px-4 text-center" data-dropzone>
        <span class="text-sm font-semibold">Drop image or video</span>
        <span class="mt-1 text-xs text-black/55">JPEG, PNG, WebP, MP4, MOV</span>
        <span class="mt-3 max-w-full truncate rounded-md bg-white px-3 py-1 text-xs font-medium text-black/60" data-file-name>No file selected</span>
        <input class="sr-only" type="file" name="media" accept="image/*,video/*" multiple required>
      </label>
      <button class="mt-3 w-full rounded-md bg-ink px-4 py-2 text-sm font-semibold text-white">Upload</button>
    </form>
    <div class="mt-5 grid grid-cols-2 gap-3" id="media-grid">
      <% media.forEach(function(item) { %>
        <%
          const isVideo = item.mime_type && item.mime_type.startsWith('video/');
          const videoSrc = isVideo ? '/' + item.file_path : null;
        %>
        <div class="group relative" data-media-card data-id="<%= item.id %>">
          <label class="block cursor-pointer rounded-md border border-black/10 p-2 transition-colors" data-media-label>
            <input class="sr-only" type="checkbox" data-media-cb value="<%= item.id %>">
            <% if (item.thumbnail_path) { %>
              <img src="/<%= item.thumbnail_path %>" class="aspect-square w-full rounded object-cover" alt="">
            <% } else { %>
              <div class="aspect-square rounded bg-black/5"></div>
            <% } %>
            <p class="mt-2 truncate text-xs"><%= item.original_name %></p>
            <% if (isVideo && item.width && item.height) { %>
              <p class="text-xs text-black/40"><%= item.width %>&times;<%= item.height %></p>
            <% } %>
          </label>
          <span class="pointer-events-none absolute left-2 top-2 hidden h-5 w-5 items-center justify-center rounded-full bg-mint text-xs font-bold text-white" data-order-badge></span>
          <% if (isVideo) { %>
            <button type="button"
                    data-crop="<%= item.id %>"
                    data-crop-src="<%= videoSrc %>"
                    title="Crop video"
                    class="absolute bottom-8 right-1 flex items-center gap-1 rounded bg-black/70 px-1.5 py-0.5 text-xs font-medium text-white opacity-0 transition-opacity group-hover:opacity-100">
              &#9881; Crop
            </button>
          <% } else { %>
            <button type="button"
                    data-crop-image="<%= item.id %>"
                    data-crop-src="/<%= item.thumbnail_path %>"
                    data-img-w="<%= item.width || 0 %>"
                    data-img-h="<%= item.height || 0 %>"
                    title="Crop image"
                    class="absolute bottom-8 right-1 flex items-center gap-1 rounded bg-black/70 px-1.5 py-0.5 text-xs font-medium text-white opacity-0 transition-opacity group-hover:opacity-100">
              &#9881; Crop
            </button>
          <% } %>
          <form method="post" action="/posts/media/<%= item.id %>?_method=DELETE" class="absolute right-1 top-1">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" title="Remove" class="flex h-5 w-5 items-center justify-center rounded-full bg-black/60 text-xs font-bold text-white opacity-0 transition-opacity group-hover:opacity-100">&times;</button>
          </form>
        </div>
      <% }) %>
    </div>
    <div class="mt-3 flex items-center gap-2">
      <span class="text-xs text-black/55"><span id="sel-count">0</span> selected <span class="text-black/30">(max 10)</span></span>
      <span id="carousel-tag" class="hidden rounded-full bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700">Carousel</span>
    </div>
  </section>
  <form id="post-form" method="post" action="/posts" class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-xl font-semibold">Create post</h1>
        <p class="text-sm text-black/55">One composer with platform-aware fields.</p>
      </div>
    </div>
    <div class="mt-5 flex items-center justify-between">
      <label class="block text-sm font-medium">Caption</label>
      <div class="relative">
        <button type="button" id="emoji-toggle" class="flex items-center gap-1.5 rounded-md border border-black/10 px-2.5 py-1 text-sm hover:bg-black/5 transition-colors" title="Insert emoji">
          😊 <span class="text-xs text-black/55">Emoji</span>
        </button>
        <div id="emoji-picker" class="hidden absolute z-30 right-0 top-full mt-1 w-80 rounded-xl border border-black/10 bg-white shadow-xl" style="max-height:300px;overflow:hidden"></div>
      </div>
    </div>
    <textarea name="caption" rows="7" maxlength="5000" class="mt-1 w-full rounded-md border border-black/15 px-3 py-2" data-caption></textarea>
    <p class="mt-1 text-xs text-black/50"><span data-caption-count>0</span> characters. Instagram limit is 2,200.</p>
    <div class="mt-5">
      <p class="text-sm font-medium">Publish to</p>
      <% if (brandAccounts.length) { %>
        <p class="mt-0.5 text-xs text-black/50">Select one or more brand accounts — all their platforms will be targeted.</p>
        <div class="mt-2 grid gap-2 sm:grid-cols-2">
          <% brandAccounts.forEach(function(brand) { %>
            <%
              const platformColor = {
                instagram:'bg-gradient-to-r from-purple-500 to-pink-500 text-white',
                facebook:'bg-blue-600 text-white', pinterest:'bg-[#E60023] text-white',
                youtube:'bg-[#FF0000] text-white', tiktok:'bg-[#010101] text-white'
              };
              const platformLabel = {
                instagram:'Instagram', facebook:'Facebook Page',
                pinterest:'Pinterest', youtube:'YouTube', tiktok:'TikTok'
              };
            %>
            <label class="flex cursor-pointer flex-col rounded-md border border-black/10 px-3 py-3 has-[:checked]:border-mint has-[:checked]:bg-emerald-50">
              <div class="flex items-center justify-between">
                <span class="text-sm font-semibold"><%= brand.name %></span>
                <input type="checkbox" name="brandAccountIds" value="<%= brand.id %>"
                       data-brand
                       data-platforms="<%= brand.members.map(function(m){return m.platform;}).join(',') %>"
                       data-has-watermark="<%= brand.watermark_path ? '1' : '' %>">
              </div>
              <div class="mt-2 flex flex-wrap gap-1">
                <% (brand.members || []).forEach(function(m) { %>
                  <span class="rounded-full px-2 py-0.5 text-xs font-medium <%= platformColor[m.platform] || 'bg-black/10 text-black/70' %>">
                    <%= platformLabel[m.platform] || m.platform %> @<%= m.username %>
                  </span>
                <% }) %>
                <% if (!brand.members.length) { %>
                  <span class="text-xs text-black/40">No platforms linked</span>
                <% } %>
              </div>
            </label>
          <% }) %>
        </div>
        <details class="mt-3">
          <summary class="cursor-pointer text-xs text-black/50 hover:text-black">Or select individual platforms</summary>
          <div class="mt-2 grid gap-2 sm:grid-cols-2">
            <% accounts.forEach(function(account) { %>
              <label class="flex cursor-pointer items-center justify-between rounded-md border border-black/10 px-3 py-2 has-[:checked]:border-mint has-[:checked]:bg-emerald-50">
                <span><span class="block text-sm font-semibold capitalize"><%= account.platform %></span><span class="text-xs text-black/55"><%= account.username %></span></span>
                <input type="checkbox" name="accounts" value="<%= account.id %>" data-platform="<%= account.platform %>">
              </label>
            <% }) %>
          </div>
        </details>
      <% } else { %>
        <div class="mt-2 grid gap-2 sm:grid-cols-2">
          <% accounts.forEach(function(account) { %>
            <label class="flex cursor-pointer items-center justify-between rounded-md border border-black/10 px-3 py-3 has-[:checked]:border-mint has-[:checked]:bg-emerald-50">
              <span><span class="block text-sm font-semibold capitalize"><%= account.platform %></span><span class="text-xs text-black/55"><%= account.username %></span></span>
              <input type="checkbox" name="accounts" value="<%= account.id %>" data-platform="<%= account.platform %>">
            </label>
          <% }) %>
        </div>
        <% if (!accounts.length) { %><p class="mt-2 text-sm text-black/55">Connect accounts before publishing.</p><% } %>
        <p class="mt-2 text-xs text-black/40"><a href="/accounts" class="underline">Create a brand account</a> to group platforms together.</p>
      <% } %>
    </div>
    <!-- Watermark toggle — shown only when a brand with a watermark is selected -->
    <div id="watermark-toggle-row" class="hidden mt-4 flex items-center justify-between rounded-md border border-black/10 bg-black/[0.02] px-4 py-3">
      <div class="flex items-center gap-2">
        <span class="text-lg">🔲</span>
        <div>
          <p class="text-sm font-medium">Apply brand watermark</p>
          <p class="text-xs text-black/45">Overlay your brand logo on all media in this post</p>
        </div>
      </div>
      <label class="relative inline-flex cursor-pointer items-center">
        <input type="checkbox" name="applyWatermark" value="1" id="apply-watermark-cb" class="sr-only peer" checked>
        <div class="h-6 w-11 rounded-full bg-black/20 peer-checked:bg-mint transition-colors after:absolute after:left-[2px] after:top-[2px] after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-5"></div>
      </label>
    </div>

    <div class="mt-5 grid gap-4 sm:grid-cols-2" data-platform-fields>
      <div data-field="youtube" class="hidden rounded-md border border-black/10 p-3">
        <label class="block text-sm font-medium">YouTube title</label>
        <input name="youtubeTitle" maxlength="100" class="mt-1 w-full rounded-md border border-black/15 px-3 py-2">
      </div>
      <div data-field="tiktok" class="hidden rounded-md border border-black/10 p-3">
        <label class="block text-sm font-medium">TikTok title / caption</label>
        <input name="tiktokTitle" maxlength="2200" class="mt-1 w-full rounded-md border border-black/15 px-3 py-2" placeholder="Defaults to main caption">
        <label class="mt-3 block text-sm font-medium">Privacy</label>
        <select name="tiktokPrivacy" class="mt-1 w-full rounded-md border border-black/15 px-3 py-2 text-sm">
          <option value="PUBLIC_TO_EVERYONE">Public</option>
          <option value="FOLLOWER_OF_CREATOR">Followers only</option>
          <option value="MUTUAL_FOLLOW_FRIENDS">Friends</option>
          <option value="SELF_ONLY">Only me (testing)</option>
        </select>
      </div>
      <div data-field="pinterest" class="hidden rounded-md border border-black/10 p-3">
        <label class="block text-sm font-medium">Board <span class="text-red-500">*</span></label>
        <% if (pinterestBoards.length) { %>
          <select name="pinterestBoardId" class="mt-1 w-full rounded-md border border-black/15 px-3 py-2 text-sm">
            <option value="">— select a board —</option>
            <% pinterestBoards.forEach(function(board) { %>
              <option value="<%= board.id %>"><%= board.name %></option>
            <% }) %>
          </select>
        <% } else { %>
          <p class="mt-1 text-xs text-black/50">No boards found. <a href="/accounts/pinterest/connect" class="underline">Connect Pinterest</a> to load your boards.</p>
        <% } %>
        <label class="mt-3 block text-sm font-medium">Pin title</label>
        <input name="pinterestTitle" maxlength="100" class="mt-1 w-full rounded-md border border-black/15 px-3 py-2">
        <label class="mt-3 block text-sm font-medium">Destination link</label>
        <input name="pinterestDestinationUrl" class="mt-1 w-full rounded-md border border-black/15 px-3 py-2" placeholder="https://...">
        <label class="mt-3 block text-sm font-medium">Description</label>
        <textarea name="pinterestDescription" rows="3" maxlength="500" class="mt-1 w-full rounded-md border border-black/15 px-3 py-2"></textarea>
      </div>
    </div>
    <div class="mt-5 rounded-md border border-black/10 p-3">
      <p class="text-sm font-medium">Publish time</p>
      <div class="mt-2 flex flex-wrap gap-3">
        <label class="flex items-center gap-2 text-sm"><input type="radio" name="publishMode" value="now" checked> Now</label>
        <label class="flex items-center gap-2 text-sm"><input type="radio" name="publishMode" value="schedule"> Schedule</label>
      </div>
      <input type="datetime-local" name="scheduledFor" class="mt-3 hidden rounded-md border border-black/15 px-3 py-2" data-schedule-input>
    </div>
    <button class="mt-6 rounded-md bg-mint px-5 py-2.5 text-sm font-semibold text-white">Publish</button>
  </form>
</div>

<!-- ── Image Crop modal ───────────────────────────────────────────────────── -->
<div id="img-crop-modal" style="display:none" class="fixed inset-0 z-50 items-center justify-center bg-black/75 p-4">
  <div class="w-full max-w-2xl rounded-xl bg-white shadow-2xl">
    <div class="flex flex-wrap items-center gap-2 border-b border-black/10 px-5 py-4">
      <span class="mr-1 text-sm font-semibold">Aspect ratio:</span>
      <% [
        ['1/1',      '1:1 Square',      'ig fb tk'],
        ['4/5',      '4:5 Portrait',    'ig'],
        ['1.91/1',   '1.91:1 Wide',     'ig fb'],
        ['9/16',     '9:16 Story',      'ig tk'],
        ['2/3',      '2:3 Pinterest',   'pt'],
        ['free',     'Free',            '']
      ].forEach(function(r) { %>
        <button type="button" data-img-ratio="<%= r[0] %>"
                class="img-crop-ratio-btn rounded-full border border-black/20 px-2.5 py-0.5 text-xs font-medium hover:bg-black/5">
          <%= r[1] %><% if (r[2]) { %> <span class="opacity-40"><%= r[2] %></span><% } %>
        </button>
      <% }) %>
    </div>
    <div class="flex items-center justify-center bg-black px-4 py-4" style="min-height:200px">
      <div id="img-crop-wrap" class="relative" style="line-height:0">
        <img id="img-crop-img" src="" alt="" draggable="false"
             style="display:block;max-width:100%;max-height:55vh;user-select:none">
        <div id="img-crop-box"
             style="position:absolute;border:2px solid #fff;box-shadow:0 0 0 9999px rgba(0,0,0,0.55);cursor:move;display:none">
          <div class="img-crop-handle" data-h="nw" style="position:absolute;left:-5px;top:-5px;width:12px;height:12px;background:#fff;cursor:nw-resize;border-radius:2px"></div>
          <div class="img-crop-handle" data-h="ne" style="position:absolute;right:-5px;top:-5px;width:12px;height:12px;background:#fff;cursor:ne-resize;border-radius:2px"></div>
          <div class="img-crop-handle" data-h="sw" style="position:absolute;left:-5px;bottom:-5px;width:12px;height:12px;background:#fff;cursor:sw-resize;border-radius:2px"></div>
          <div class="img-crop-handle" data-h="se" style="position:absolute;right:-5px;bottom:-5px;width:12px;height:12px;background:#fff;cursor:se-resize;border-radius:2px"></div>
        </div>
      </div>
    </div>
    <form id="img-crop-form" method="post" action="" class="flex items-center justify-between gap-3 px-5 py-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" id="img-crop-x" name="x" value="0">
      <input type="hidden" id="img-crop-y" name="y" value="0">
      <input type="hidden" id="img-crop-w" name="w" value="100">
      <input type="hidden" id="img-crop-h" name="h" value="100">
      <span id="img-crop-info" class="text-xs text-black/40"></span>
      <div class="flex gap-2">
        <button type="button" id="img-crop-cancel-btn"
                class="rounded-md border border-black/20 px-4 py-2 text-sm font-medium">Cancel</button>
        <button type="submit"
                class="rounded-md bg-mint px-4 py-2 text-sm font-semibold text-white">Apply Crop</button>
      </div>
    </form>
  </div>
</div>

<!-- ── Video Crop modal ────────────────────────────────────────────────────── -->
<div id="crop-modal" style="display:none" class="fixed inset-0 z-50 items-center justify-center bg-black/75 p-4">
  <div class="w-full max-w-2xl rounded-xl bg-white shadow-2xl">
    <!-- Header -->
    <div class="flex flex-wrap items-center gap-2 border-b border-black/10 px-5 py-4">
      <span class="mr-1 text-sm font-semibold">Aspect ratio:</span>
      <% [['9/16','9:16 Reels'],['1/1','1:1 Square'],['4/5','4:5 Portrait'],['16/9','16:9 Wide'],['free','Free']].forEach(function(r){ %>
        <button type="button" data-ratio="<%= r[0] %>"
                class="rounded-full border border-black/20 px-2.5 py-0.5 text-xs font-medium hover:bg-black/5 crop-ratio-btn">
          <%= r[1] %>
        </button>
      <% }) %>
    </div>

    <!-- Video + crop overlay -->
    <div class="flex items-center justify-center bg-black px-4 py-4" style="min-height:200px">
      <div id="crop-wrap" class="relative" style="line-height:0">
        <video id="crop-video" muted playsinline
               style="display:block;max-width:100%;max-height:55vh"></video>
        <!-- Crop box -->
        <div id="crop-box"
             style="position:absolute;border:2px solid #fff;box-shadow:0 0 0 9999px rgba(0,0,0,0.55);cursor:move;display:none">
          <div class="crop-handle" data-h="nw" style="position:absolute;left:-5px;top:-5px;width:12px;height:12px;background:#fff;cursor:nw-resize;border-radius:2px"></div>
          <div class="crop-handle" data-h="ne" style="position:absolute;right:-5px;top:-5px;width:12px;height:12px;background:#fff;cursor:ne-resize;border-radius:2px"></div>
          <div class="crop-handle" data-h="sw" style="position:absolute;left:-5px;bottom:-5px;width:12px;height:12px;background:#fff;cursor:sw-resize;border-radius:2px"></div>
          <div class="crop-handle" data-h="se" style="position:absolute;right:-5px;bottom:-5px;width:12px;height:12px;background:#fff;cursor:se-resize;border-radius:2px"></div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <form id="crop-form" method="post" action="" class="flex items-center justify-between gap-3 px-5 py-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" id="crop-x" name="x" value="0">
      <input type="hidden" id="crop-y" name="y" value="0">
      <input type="hidden" id="crop-w" name="w" value="100">
      <input type="hidden" id="crop-h" name="h" value="100">
      <span id="crop-info" class="text-xs text-black/40"></span>
      <div class="flex gap-2">
        <button type="button" id="crop-cancel-btn"
                class="rounded-md border border-black/20 px-4 py-2 text-sm font-medium">Cancel</button>
        <button type="submit"
                class="rounded-md bg-mint px-4 py-2 text-sm font-semibold text-white">Apply Crop</button>
      </div>
    </form>
  </div>
</div>
