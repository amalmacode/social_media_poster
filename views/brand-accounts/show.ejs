<%
  const platformColor = {
    instagram: 'bg-gradient-to-r from-purple-500 to-pink-500 text-white',
    facebook:  'bg-blue-600 text-white',
    pinterest: 'bg-[#E60023] text-white',
    youtube:   'bg-[#FF0000] text-white',
    tiktok:    'bg-[#010101] text-white'
  };
  const platformLabel = {
    instagram: 'Instagram', facebook: 'Facebook Page',
    pinterest: 'Pinterest', youtube: 'YouTube', tiktok: 'TikTok'
  };
%>
<div class="space-y-6 max-w-2xl">
  <div class="flex items-center gap-3">
    <a href="/accounts" class="text-sm text-black/50 hover:text-black">← Accounts</a>
    <span class="text-black/20">/</span>
    <h1 class="text-2xl font-semibold"><%= brand.name %></h1>
  </div>

  <%- include('../partials/flash') %>

  <!-- Rename -->
  <section class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
    <h2 class="text-sm font-semibold text-black/60 uppercase tracking-wide">Rename</h2>
    <form method="post" action="/accounts/brands/<%= brand.id %>/rename" class="mt-3 flex gap-2">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="text" name="name" value="<%= brand.name %>" maxlength="60"
             class="flex-1 rounded-md border border-black/15 px-3 py-2 text-sm">
      <button class="rounded-md bg-ink px-4 py-2 text-sm font-semibold text-white">Save</button>
    </form>
  </section>

  <!-- Current members -->
  <section class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
    <h2 class="text-sm font-semibold text-black/60 uppercase tracking-wide">Platform connections (<%= brand.members.length %>)</h2>
    <% if (!brand.members.length) { %>
      <p class="mt-3 text-sm text-black/50">No platforms added yet. Add one below.</p>
    <% } else { %>
      <ul class="mt-3 divide-y divide-black/5">
        <% brand.members.forEach(function(m) { %>
          <li class="flex items-center justify-between py-2.5">
            <div class="flex items-center gap-2">
              <span class="rounded-full px-2.5 py-0.5 text-xs font-semibold <%= platformColor[m.platform] || 'bg-black/10 text-black/70' %>">
                <%= platformLabel[m.platform] || m.platform %>
              </span>
              <span class="text-sm font-medium">@<%= m.username %></span>
            </div>
            <form method="post" action="/accounts/brands/<%= brand.id %>/members/<%= m.connected_account_id %>?_method=DELETE"
                  data-confirm="Remove this platform from the brand?">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="rounded px-2 py-1 text-xs font-medium text-red-600 hover:bg-red-50">Remove</button>
            </form>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>

  <!-- Add platform -->
  <% if (unassigned.length) { %>
    <section class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
      <h2 class="text-sm font-semibold text-black/60 uppercase tracking-wide">Add platform</h2>
      <form method="post" action="/accounts/brands/<%= brand.id %>/members" class="mt-3 flex gap-2">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <select name="connectedAccountId" class="flex-1 rounded-md border border-black/15 px-3 py-2 text-sm">
          <option value="">— select a connection —</option>
          <% unassigned.forEach(function(a) { %>
            <option value="<%= a.id %>"><%= platformLabel[a.platform] || a.platform %> — @<%= a.username %></option>
          <% }) %>
        </select>
        <button class="rounded-md bg-mint px-4 py-2 text-sm font-semibold text-white">Add</button>
      </form>
    </section>
  <% } else { %>
    <p class="text-sm text-black/50">All platform connections are already in this brand account.</p>
  <% } %>

  <!-- Watermark -->
  <section class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
    <h2 class="text-sm font-semibold text-black/60 uppercase tracking-wide">Watermark</h2>
    <p class="mt-1 text-xs text-black/45">PNG or WebP with transparency. Applied automatically to every image and video posted under this brand.</p>

    <% if (brand.watermark_path) { %>
      <div class="mt-4 grid gap-5 lg:grid-cols-2">

        <!-- Settings form -->
        <form method="post" action="/accounts/brands/<%= brand.id %>/watermark-settings">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="flex items-center justify-between">
            <label class="text-xs font-medium text-black/60">Size</label>
            <span class="rounded-full bg-mint/10 px-2 py-0.5 text-xs font-semibold text-mint" id="wm-size-label"><%= brand.watermark_size || 20 %>% of width</span>
          </div>
          <input id="wm-size" type="range" name="size" min="5" max="50" step="5"
                 value="<%= brand.watermark_size || 20 %>"
                 class="mt-1 w-full accent-mint">

          <div class="mt-4 flex items-center justify-between">
            <label class="text-xs font-medium text-black/60">Opacity</label>
            <span class="rounded-full bg-mint/10 px-2 py-0.5 text-xs font-semibold text-mint" id="wm-opacity-label"><%= Math.round((brand.watermark_opacity || 0.5) * 100) %>%</span>
          </div>
          <input id="wm-opacity" type="range" name="opacity" min="5" max="100" step="5"
                 value="<%= Math.round((brand.watermark_opacity || 0.5) * 100) %>"
                 class="mt-1 w-full accent-mint">

          <label class="mt-4 block text-xs font-medium text-black/60">Position</label>
          <select id="wm-position" name="position" class="mt-1 w-full rounded-md border border-black/15 px-3 py-1.5 text-sm">
            <% [['center','Center (recommended)'],['top-left','Top left'],['top-right','Top right'],['bottom-left','Bottom left'],['bottom-right','Bottom right']].forEach(function(p){ %>
              <option value="<%= p[0] %>" <%= brand.watermark_position === p[0] ? 'selected' : '' %>><%= p[1] %></option>
            <% }) %>
          </select>

          <button class="mt-4 rounded-md bg-mint px-4 py-1.5 text-sm font-semibold text-white">Save settings</button>
        </form>

        <form method="post" action="/accounts/brands/<%= brand.id %>/watermark?_method=DELETE"
              class="mt-2" data-confirm="Remove the watermark from this brand?">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="text-xs font-medium text-red-500 hover:underline">Remove watermark</button>
        </form>

        <!-- Live preview -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <p class="text-xs font-medium text-black/60">Live preview</p>
            <p class="text-xs text-black/30">Updates as you adjust sliders</p>
          </div>
          <div id="wm-preview"
               class="relative overflow-hidden rounded-lg border border-black/10"
               style="aspect-ratio:16/9;background:repeating-conic-gradient(#d1d5db 0% 25%,#f3f4f6 0% 50%) 0 0/24px 24px">
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
              <span class="rounded bg-black/10 px-2 py-1 text-xs text-black/30 select-none">Your photo / video</span>
            </div>
            <img id="wm-preview-img"
                 src="/<%= brand.watermark_path %>"
                 alt=""
                 class="absolute max-w-none pointer-events-none select-none"
                 style="width:<%= brand.watermark_size || 20 %>%;opacity:<%= brand.watermark_opacity || 0.5 %>">
          </div>
          <p class="mt-1 text-xs text-black/30">Approximate — exact rendering done by ffmpeg at publish time</p>
        </div>

      </div>
    <% } %>

    <!-- Upload new watermark — CSRF token must be in query string for multipart/form-data -->
    <form method="post" action="/accounts/brands/<%= brand.id %>/watermark?_csrf=<%= encodeURIComponent(csrfToken) %>" enctype="multipart/form-data" class="mt-4 <%= brand.watermark_path ? 'pt-4 border-t border-black/8' : '' %>">
      <p class="text-xs font-medium text-black/60 mb-2"><%= brand.watermark_path ? 'Replace watermark' : 'Upload watermark' %></p>
      <div class="flex flex-wrap gap-3 items-end">
        <div>
          <label class="block text-xs text-black/50 mb-1">Image (PNG/WebP, max 5 MB)</label>
          <input type="file" name="watermark" accept="image/png,image/webp" required
                 class="text-sm text-black/70 file:mr-2 file:rounded file:border-0 file:bg-black/5 file:px-3 file:py-1 file:text-xs file:font-medium">
        </div>
        <% if (!brand.watermark_path) { %>
          <div>
            <label class="block text-xs text-black/50 mb-1">Size — <span id="new-size-label">20% of media</span></label>
            <input type="range" name="size" min="5" max="50" step="5" value="20"
                   class="w-36 accent-mint"
                   oninput="document.getElementById('new-size-label').textContent = this.value + '% of media'">
          </div>
          <div>
            <label class="block text-xs text-black/50 mb-1">Opacity — <span id="new-opacity-label">50%</span></label>
            <input type="range" name="opacity" min="5" max="100" step="5" value="50"
                   class="w-36 accent-mint"
                   oninput="document.getElementById('new-opacity-label').textContent = this.value + '%'">
          </div>
          <div>
            <label class="block text-xs text-black/50 mb-1">Position</label>
            <select name="position" class="rounded-md border border-black/15 px-3 py-1.5 text-sm">
              <option value="center">Center</option>
              <option value="top-left">Top left</option>
              <option value="top-right">Top right</option>
              <option value="bottom-left">Bottom left</option>
              <option value="bottom-right">Bottom right</option>
            </select>
          </div>
        <% } %>
        <button class="rounded-md bg-ink px-4 py-2 text-sm font-semibold text-white">Upload</button>
      </div>
    </form>
  </section>

  <!-- Danger zone -->
  <section class="rounded-lg border border-red-100 bg-white p-5 shadow-sm">
    <h2 class="text-sm font-semibold text-red-500 uppercase tracking-wide">Delete brand account</h2>
    <p class="mt-1 text-xs text-black/50">Removes the brand and its platform groupings. Platform connections themselves are not deleted.</p>
    <form method="post" action="/accounts/brands/<%= brand.id %>?_method=DELETE" class="mt-3"
          data-confirm="Delete brand account <%= brand.name %>?">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="rounded-md border border-red-200 px-3 py-1.5 text-sm font-medium text-red-700 hover:bg-red-50">
        Delete <%= brand.name %>
      </button>
    </form>
  </section>
</div>
