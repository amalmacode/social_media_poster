<div class="flex flex-col gap-5">
  <div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-center">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight">Dashboard</h1>
      <p class="text-sm text-black/60">Plan, schedule, and monitor every platform.</p>
    </div>
    <a href="/posts/new" class="inline-flex items-center justify-center rounded-md bg-ink px-4 py-2.5 text-sm font-semibold text-white">Create Post</a>
  </div>
  <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <%- include('../partials/stat', { label: 'Active', value: counts.active || 0 }) %>
    <%- include('../partials/stat', { label: 'Scheduled', value: counts.scheduled || 0 }) %>
    <%- include('../partials/stat', { label: 'Failed', value: counts.failed || 0 }) %>
    <%- include('../partials/stat', { label: 'Total posts', value: counts.total || 0 }) %>
  </section>
  <section class="grid gap-5 lg:grid-cols-[1fr_360px]">
    <div class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-semibold">Recent posts</h2>
        <a class="text-sm font-medium text-mint" href="/history">View all</a>
      </div>
      <%- include('../partials/postTable', { posts: recentPosts }) %>
    </div>
    <aside class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
      <h2 class="text-lg font-semibold">Connected platforms</h2>
      <div class="mt-4 space-y-3">
        <% if (!accounts.length) { %>
          <p class="text-sm text-black/60">No accounts connected yet.</p>
        <% } %>
        <% accounts.forEach(function(account) { %>
          <div class="flex items-center justify-between rounded-md border border-black/10 px-3 py-2">
            <div>
              <p class="text-sm font-semibold capitalize"><%= account.platform %></p>
              <p class="text-xs text-black/55"><%= account.username %></p>
            </div>
            <span class="h-2.5 w-2.5 rounded-full bg-mint"></span>
          </div>
        <% }) %>
      </div>
      <a href="/accounts" class="mt-4 inline-flex w-full justify-center rounded-md border border-black/10 px-4 py-2 text-sm font-semibold">Manage accounts</a>
    </aside>
  </section>
</div>
