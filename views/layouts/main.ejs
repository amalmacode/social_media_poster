<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title ? `${title} | SocialPost` : 'SocialPost' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = { theme: { extend: { colors: { ink: '#16201c', mint: '#27b184', coral: '#f26b5b' } } } }
    </script>
  </head>
  <body class="min-h-screen bg-[#f7f8f5] text-ink">
    <% if (currentUser) { %><%- include('../partials/nav') %><% } %>
    <main class="<%= currentUser ? 'mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8' : '' %>">
      <%- include('../partials/flash') %>
      <%- body %>
    </main>
    <script src="/public/js/app.js?v=<%= Date.now() %>"></script>
    <footer class="mt-12 border-t border-black/5 py-6 text-center text-xs text-black/30">
      <a href="/privacy" class="hover:text-black/60">Privacy Policy</a>
      <span class="mx-2">·</span>
      <a href="/terms" class="hover:text-black/60">Terms of Service</a>
      <span class="mx-2">·</span>
      <a href="/data-deletion" class="hover:text-black/60">Data Deletion</a>
    </footer>
  </body>
</html>
